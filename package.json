{
  "name": "cloudflare-cli",
  "version": "0.1.0",
  "description": "CLI for the cloudflare API",
  "type": "module",
  "bin": {
    "cloudflare-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "api2cli": {
    "app": "cloudflare",
    "credsEntry": "global/dev/cloudflare",
    "authType": "bearer"
  }
}
